NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SHOP_PHONE=01234 567890

# Reorder alerts — email to receive low-stock notifications
REORDER_ALERT_EMAIL=you@yourshop.com

# QuickBooks Online (https://developer.intuit.com → My Apps → create app)
# Leave blank to disable QuickBooks integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QUICKBOOKS_SANDBOX=true

# Daily Digest Email — address to receive the daily shop summary
DIGEST_EMAIL=owner@example.com

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
