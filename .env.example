# ─────────────────────────────────────────────
#  Repair Shop — Environment Variables
#  Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────

# Supabase (https://supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# Twilio SMS (https://console.twilio.com)
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+441234567890
# Twilio WhatsApp — set to your WhatsApp-enabled number to enable WhatsApp notifications (optional)
# TWILIO_WHATSAPP_NUMBER=+447700000000

# Resend Email (https://resend.com → API Keys)
RESEND_API_KEY=REPLACE_WITH_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=hello@yourshop.co.uk
RESEND_FROM_NAME=Your Shop Name

# App settings
NEXT_PUBLIC_APP_NAME=Your Repair Shop
NEXT_PUBLIC_APP_URL=https://your-app-url.com
NEXT_PUBLIC_SHOP_PHONE=01234 567890

# Reorder alerts — email to receive low-stock notifications
REORDER_ALERT_EMAIL=you@yourshop.com

# QuickBooks Online (https://developer.intuit.com → My Apps → create app)
# Leave blank to disable QuickBooks integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://your-app-url.com/api/quickbooks/callback
QUICKBOOKS_SANDBOX=true

# Daily Digest Email — address to receive the daily shop summary
DIGEST_EMAIL=owner@example.com

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@example.com
